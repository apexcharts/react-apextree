{
  "name": "react-apextree",
  "version": "2.0.0",
  "description": "React wrapper for ApexTree - a JavaScript library for creating organizational and hierarchical charts",
  "author": "ApexCharts",
  "license": "See LICENSE in LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/apexcharts/react-apextree"
  },
  "homepage": "https://github.com/apexcharts/react-apextree#readme",
  "bugs": {
    "url": "https://github.com/apexcharts/react-apextree/issues"
  },
  "keywords": [
    "react",
    "apextree",
    "tree",
    "chart",
    "organizational-chart",
    "org-chart",
    "hierarchy",
    "diagram",
    "svg"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "demo": "npm run --prefix demo dev",
    "demo:build": "npm run --prefix demo build"
  },
  "peerDependencies": {
    "apextree": ">=1.9.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "apextree": "^1.9.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}